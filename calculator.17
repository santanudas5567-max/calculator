         <!-- Main Section -->
          <div class="content">
            <p>
                <script>
                    alert("Welcome to my page!")
                    var num1, num2;
                    var result;

                    num1 = 10;
                    num2 = 15;
                    result = num1 + num2;
                    var sub = num1 - num2;
                    var mult = num1 * num2;
                    document.write("<br>" + "The sum is: " + result);
                    document.write("<br>" + "The result is: " + sub);
                    document.write("<br>" + "The result is: " + mult);
                </script>
            </p>
